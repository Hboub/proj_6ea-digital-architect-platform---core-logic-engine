# Application Configuration
DEBUG=true
LOG_LEVEL=info
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/digital_architect_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Pinecone Vector Database Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=digital-architect-embeddings

# API Keys and Secrets
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32
API_KEY_SALT=your_api_key_salt_here

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# Redis Cache Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Monitoring and Observability
SENTRY_DSN=
ENABLE_METRICS=true
ENABLE_TRACING=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100
